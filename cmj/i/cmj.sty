%  GRAPHICS PATH  (covers both papers' image dirs)
% ============================================================
\graphicspath{%
  {articles/papers/shannon-polar-codes/}%
  {articles/papers/bragg-x-ray/}%
}

% ============================================================
%  ARTICLE REFERENCES HEADING
% ============================================================
%  Consistent "References" sub‑heading for each article
\newcommand{\articlereferences}{%
  \vspace{0.6cm}%
  \noindent{\large\bfseries\color{cmjcrimson}References}%
  \vspace{0.3cm}\par
}

