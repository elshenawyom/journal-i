%  CUSTOM COMMANDS FROM ORIGINAL PAPERS
% ============================================================
% Paper 1
\def\dent{~~~}
\def\vdent{\vspace{0.6cm}}
\renewcommand{\P}{\mathbb{P}}

% Paper 2
\newcommand{\nl}{\\[6pt]}
\newcommand{\maghri}{~~~~~}

