% ============================================================
% cmj.sty — Constructor Mathematical Journal
% Style file for the "Constructor Mathematical Journal"
% Version 1.0 · Spring 2025
% ============================================================
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{cmj}[2026/03/15 CMJ Journal Style v1.0]

% ── Typography & Fonts ──────────────────────────────────────
\RequirePackage[T1]{fontenc}
\RequirePackage[utf8]{inputenc}
\RequirePackage[sc]{mathpazo}           % Palatino text + math (universally available)
\RequirePackage{microtype}              % Microtypographic polish
\RequirePackage{setspace}

% ── Page Layout ─────────────────────────────────────────────
\RequirePackage[
  a4paper,
  top=2.5cm,
  bottom=2.5cm,
  left=2.5cm,
  right=2.5cm,
  headheight=36pt
]{geometry}

% ── Headers & Footers ──────────────────────────────────────
\RequirePackage{fancyhdr}

% ── Mathematics ────────────────────────────────────────────
\RequirePackage{amsmath, amssymb, amsthm}
\RequirePackage{physics}

% ── Graphics & Color ───────────────────────────────────────
\RequirePackage{graphicx}
\RequirePackage[table,xcdraw]{xcolor}
\RequirePackage{tikz}
\usetikzlibrary{calc, arrows.meta, decorations.markings, shadings, positioning, 3d}
\RequirePackage[most]{tcolorbox}

% ── Tables & Floats ───────────────────────────────────────
\RequirePackage{booktabs}
\RequirePackage{colortbl}
\RequirePackage{float}
\RequirePackage{caption}

% ── Algorithms ─────────────────────────────────────────────
\RequirePackage{algorithm}
\RequirePackage{algpseudocode}

% ── Utilities ──────────────────────────────────────────────
\RequirePackage{comment}
\RequirePackage{footnote}
\RequirePackage{titlesec}
\RequirePackage{enumitem}
\RequirePackage{abstract}
\RequirePackage{etoolbox}

% ── Hyperlinks (load last among standard packages) ─────────
\RequirePackage{hyperref}

% ============================================================
%  COLOR PALETTE
% ============================================================
\definecolor{cmjcrimson}{RGB}{155, 20, 30}        % deep crimson (primary)
\definecolor{cmjgold}{RGB}{186, 145, 40}          % gold (accent)
\definecolor{cmjlightcrimson}{RGB}{255, 240, 240} % blush rose (light bg)
\definecolor{cmjdark}{RGB}{35, 35, 35}
\definecolor{cmjgray}{RGB}{128, 128, 128}
\definecolor{cmjlightgray}{RGB}{230, 230, 230}

% tcolorbox accent colors
\definecolor{cmjred}{RGB}{160, 30, 30}
\definecolor{cmjthrmblue}{RGB}{100, 10, 20}        % deep burgundy
\definecolor{cmjlavender}{RGB}{120, 120, 170}

% ============================================================
%  GLOBAL TYPOGRAPHY
% ============================================================
\setstretch{1.15}
\setlength{\parindent}{0pt}
\setlength{\parskip}{0.45em}
\AtBeginDocument{\color{cmjdark}}

% ============================================================
%  HYPERREF SETUP
% ============================================================
\hypersetup{
  colorlinks  = true,
  linkcolor   = cmjcrimson,
  citecolor   = cmjcrimson!70!black,
  urlcolor    = cmjcrimson!80!black,
  pdftitle    = {Constructor Mathematical Journal},
  pdfauthor   = {Constructor University Mathematics Society}
}

% ============================================================
%  HEADERS & FOOTERS
% ============================================================
\pagestyle{fancy}
\fancyhf{}
\fancyhead[L]{\small\color{cmjgray}\itshape Constructor Mathematical Journal}
\fancyhead[R]{\small\color{cmjgray}\itshape\currentarticletitle}
\fancyfoot[C]{\small\color{cmjgray}\thepage}
\renewcommand{\headrulewidth}{0.4pt}
\renewcommand{\headrule}{%
  \hbox to\headwidth{\color{cmjlightgray}\leaders\hrule height\headrulewidth\hfill}}
\renewcommand{\footrulewidth}{0pt}

% Style for first page of each article
\fancypagestyle{articlestart}{%
  \fancyhf{}%
  \fancyfoot[C]{\small\color{cmjgray}\thepage}%
  \renewcommand{\headrulewidth}{0pt}%
}

% Style for front‑matter pages
\fancypagestyle{frontmatter}{%
  \fancyhf{}%
  \renewcommand{\headrulewidth}{0pt}%
}

% ============================================================
%  CURRENT‑ARTICLE TRACKING
% ============================================================
\newcommand{\currentarticletitle}{}
\newcommand{\setarticletitle}[1]{%
  \renewcommand{\currentarticletitle}{#1}}

% ============================================================
%  SECTION HEADING STYLES
% ============================================================
\titleformat{\section}
  {\Large\bfseries\color{cmjcrimson}}{\thesection}{1em}{}[\normalcolor]
\titleformat{\subsection}
  {\large\bfseries\color{cmjcrimson!80!black}}{\thesubsection}{1em}{}[\normalcolor]
\titleformat{\subsubsection}
  {\normalsize\bfseries\color{cmjcrimson!60!black}}{\thesubsubsection}{1em}{}[\normalcolor]

% ============================================================
%  ARTICLE COUNTER  (makes hyperref anchors unique per article)
% ============================================================
\newcounter{articlectr}

% ============================================================
%  ARTICLE HEADER
% ============================================================
%  Usage: \articleheader[Short running title]{Title}{Author}{Affiliation}{Abstract}
%  The optional first arg sets the page-header running title independently
%  of the display title. If omitted, the full title is used.
\newcommand{\articleheader}[5][]{%
  \clearpage
  \stepcounter{articlectr}%
  \thispagestyle{articlestart}%
  \ifblank{#1}{\setarticletitle{#2}}{\setarticletitle{#1}}%
  % reset per-article counters
  \setcounter{section}{0}%
  \setcounter{equation}{0}%
  \setcounter{figure}{0}%
  \setcounter{table}{0}%
  \setcounter{footnote}{0}%
  \setcounter{defnctr}{0}%
  \setcounter{notectr}{0}%
  \setcounter{thrmctr}{0}%
  % unique hyperref anchors per article
  \renewcommand{\theHsection}{art\thearticlectr.\thesection}%
  \renewcommand{\theHsubsection}{art\thearticlectr.\thesubsection}%
  \renewcommand{\theHsubsubsection}{art\thearticlectr.\thesubsubsection}%
  \renewcommand{\theHequation}{art\thearticlectr.\theequation}%
  \renewcommand{\theHfigure}{art\thearticlectr.\thefigure}%
  % decorative rule
  \noindent\textcolor{cmjgold}{\rule{\textwidth}{2pt}}%
  \vspace{0.9cm}%
  \begin{center}
    {\LARGE\bfseries\color{cmjcrimson}#2}\\[0.55cm]
    {\large #3}\\[0.2cm]
    {\normalsize\color{cmjgray}\itshape #4}
  \end{center}
  \vspace{0.45cm}%
  \noindent\textcolor{cmjcrimson}{\rule{\textwidth}{0.5pt}}%
  \vspace{0.25cm}%
  \begin{center}
    \begin{minipage}{0.88\textwidth}
      {\small\textbf{\textcolor{cmjcrimson}{Abstract.}}\ #5}
    \end{minipage}
  \end{center}
  \vspace{0.25cm}%
  \noindent\textcolor{cmjcrimson}{\rule{\textwidth}{0.5pt}}%
  \vspace{0.7cm}%
  \normalcolor
}

% ============================================================
%  TABLE‑OF‑CONTENTS ENTRY  (manual journal ToC)
% ============================================================
%  Usage: \contentsentry{Title}{Author}{label}
\newcommand{\contentsentry}[3]{%
  \noindent
  \begin{minipage}{\textwidth}
    {\large\bfseries\color{cmjcrimson}#1}\hfill{\normalsize\pageref{#3}}\\[0.12cm]
    {\normalsize\itshape\color{cmjgray}#2}
  \end{minipage}
  \vspace{0.7cm}\par
}

% ============================================================
%  tcolorbox ENVIRONMENTS  (from paper 2, journal‑themed)
% ============================================================

% --- Definitions ---
\newcounter{defnctr}
\newtcolorbox{definitionbox}[1][]{%
  colback=white, colframe=cmjred,
  colbacktitle=white, coltitle=cmjred,
  fonttitle=\bfseries,
  title=Definition~\thedefnctr:,
  boxrule=0.8pt, sharp corners, enhanced,
  width=\textwidth,
  before upper={\refstepcounter{defnctr}},
  #1
}

% --- Notes ---
\newcounter{notectr}
\newtcolorbox{notebox}[1][]{%
  colback=white, colframe=cmjlavender,
  colbacktitle=white, coltitle=cmjlavender,
  fonttitle=\bfseries,
  title=Note~\thenotectr:,
  boxrule=0.8pt, sharp corners, enhanced,
  width=\textwidth,
  before upper={\refstepcounter{notectr}},
  #1
}

% --- Theorems (tcolorbox version) ---
\newcounter{thrmctr}
\newtcolorbox{theorembox}[1][]{%
  colback=white, colframe=cmjthrmblue,
  colbacktitle=white, coltitle=cmjthrmblue,
  fonttitle=\bfseries,
  title=Theorem~\thethrmctr:,
  boxrule=0.8pt, sharp corners, enhanced,
  width=\textwidth,
  before upper={\refstepcounter{thrmctr}},
  #1
}

% ── amsthm environments (paper 1 compatibility) ───────────
\newtheorem{theorem}{Theorem}[section]
\newtheorem{corollary}{Corollary}[theorem]
\newtheorem{lemma}[theorem]{Lemma}
\theoremstyle{definition}
\newtheorem{example}{Example}

